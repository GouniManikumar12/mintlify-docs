{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aip.dev/schemas/platform-response-v1.0.json",
  "title": "PlatformResponse",
  "description": "Operator response returned to AI platforms after auction evaluation. Includes delivery status, winning bid details, monetization reservation info, render payload, tracking hooks, and delegation availability.",
  "type": "object",
  "required": [
    "spec_version",
    "recommendation_id",
    "timestamp",
    "status",
    "ttl_ms"
  ],
  "additionalProperties": false,
  "properties": {
    "spec_version": {
      "type": "string",
      "const": "1.0"
    },
    "recommendation_id": {
      "type": "string",
      "description": "Unique identifier for this recommendation."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 / RFC 3339 timestamp when the response was produced."
    },
    "status": {
      "type": "string",
      "enum": ["generated", "no_match", "error"],
      "description": "Recommendation generation status."
    },
    "recommendation": {
      "$ref": "#/$defs/recommendation"
    },
    "delegation": {
      "$ref": "#/$defs/delegation"
    },
    "tracking": {
      "$ref": "#/$defs/tracking"
    },
    "ttl_ms": {
      "type": "integer",
      "minimum": 1000,
      "maximum": 300000,
      "description": "Response time-to-live in milliseconds."
    },
    "error": {
      "$ref": "#/$defs/error"
    },
    "ext": {
      "type": "object",
      "description": "Vendor extensions.",
      "additionalProperties": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": { "const": "generated" }
        },
        "required": ["status"]
      },
      "then": {
        "required": ["recommendation"]
      }
    },
    {
      "if": {
        "properties": {
          "status": { "const": "no_match" }
        },
        "required": ["status"]
      },
      "then": {
        "not": {
          "required": ["recommendation"]
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": { "const": "error" }
        },
        "required": ["status"]
      },
      "then": {
        "required": ["error"]
      }
    }
  ],
  "$defs": {
    "recommendation": {
      "type": "object",
      "description": "Platform render instructions for the winning recommendation.",
      "required": ["format", "disclosure", "creative"],
      "additionalProperties": false,
      "properties": {
        "format": {
          "type": "string",
          "enum": ["weave", "tail", "product_card", "bridge"],
          "description": "Creative format to render."
        },
        "disclosure": {
          "type": "string",
          "description": "Disclosure label such as [Ad] or Sponsored."
        },
        "creative": {
          "$ref": "#/$defs/creative"
        },
        "offerId": {
          "type": "string",
          "description": "Unique identifier for the offer being presented."
        }
      }
    },
    "creative": {
      "type": "object",
      "description": "Combined creative object containing brand information, ad assets, and destination.",
      "required": [
        "brand_name",
        "headline",
        "description",
        "cta_text",
        "landing_page_url"
      ],
      "additionalProperties": false,
      "properties": {
        "brand_name": {
          "type": "string",
          "description": "Advertiser or brand name."
        },
        "domain": {
          "type": "string",
          "description": "Optional advertiser domain."
        },
        "headline": {
          "type": "string",
          "maxLength": 120,
          "description": "Primary ad headline."
        },
        "description": {
          "type": "string",
          "maxLength": 300,
          "description": "Ad description text."
        },
        "cta_text": {
          "type": "string",
          "maxLength": 60,
          "description": "Call-to-action text."
        },
        "follow_up_suggestion": {
          "type": "string",
          "maxLength": 240,
          "description": "Optional follow-up suggestion the platform can surface after the initial recommendation."
        },
        "logo_url": {
          "type": "string",
          "format": "uri",
          "description": "Optional brand logo asset."
        },
        "image_urls": {
          "type": "array",
          "description": "Optional creative image assets.",
          "items": {
            "type": "string",
            "format": "uri"
          }
        },
        "landing_page_url": {
          "type": "string",
          "format": "uri",
          "description": "Advertiser-controlled destination URL."
        }
      }
    },
    "delegation": {
      "type": "object",
      "description": "Delegation availability surfaced to the platform for the winning bid.",
      "additionalProperties": false,
      "properties": {
        "available": {
          "type": "boolean",
          "description": "Whether delegated execution is available for this result."
        },
        "mode": {
          "type": "string",
          "enum": ["optional", "recommended", "required"],
          "description": "Delegation behavior expected by the operator."
        },
        "trigger": {
          "type": "string",
          "enum": ["user_action", "explicit_consent", "operator_initiated"],
          "description": "How delegation may be activated."
        },
        "cta_text": {
          "type": "string",
          "maxLength": 80,
          "description": "Delegation-specific call-to-action text."
        }
      }
    },
    "tracking": {
      "type": "object",
      "description": "Optional downstream tracking endpoints or identifiers.",
      "additionalProperties": false,
      "properties": {
        "exposure_url": {
          "type": "string",
          "format": "uri"
        },
        "followup_exposure_url": {
          "type": "string",
          "format": "uri"
        },
        "click_url": {
          "type": "string",
          "format": "uri"
        },
        "conversion_url": {
          "type": "string",
          "format": "uri"
        },
        "followup_engagement_url": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "error": {
      "type": "object",
      "description": "Error payload when status=error.",
      "required": ["code", "message"],
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        }
      }
    }
  },
  "examples": [
    {
      "spec_version": "1.0",
      "recommendation_id": "rec_981",
      "timestamp": "2026-03-26T18:00:02Z",
      "status": "generated",
      "recommendation": {
        "format": "weave",
        "disclosure": "[Ad]",
        "creative": {
          "brand_name": "Nimbus",
          "domain": "nimbus.example.com",
          "headline": "Scale your CRM",
          "description": "Built for founders.",
          "cta_text": "Try for free",
          "follow_up_suggestion": "Ask Nimbus to draft a migration plan for your current CRM.",
          "logo_url": "https://cdn.example.com/nimbus/logo.png",
          "image_urls": [
            "https://cdn.example.com/nimbus/crm.png"
          ],
          "landing_page_url": "https://nimbus.example.com/signup"
        },
        "offerId": "offer_12345"
      },
      "delegation": {
        "available": true,
        "mode": "optional",
        "trigger": "user_action",
        "cta_text": "Continue with Nimbus"
      },
      "tracking": {
        "exposure_url": "https://track.example.com/impression/stk_abcxyz123",
        "followup_exposure_url": "https://track.example.com/follow-up-impression/stk_abcxyz123",
        "click_url": "https://track.example.com/click/stk_abcxyz123",
        "conversion_url": "https://track.example.com/conversion/stk_abcxyz123",
        "followup_engagement_url": "https://track.example.com/follow-up-engagement/stk_abcxyz123"
      },
      "ttl_ms": 60000
    },
    {
      "spec_version": "1.0",
      "recommendation_id": "rec_982",
      "timestamp": "2026-03-26T18:00:02Z",
      "status": "no_match",
      "ttl_ms": 60000
    }
  ]
}
