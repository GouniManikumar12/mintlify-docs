{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aip.org/schemas/platform-request.json",
  "title": "PlatformRequest",
  "description": "Platform → Operator. User context + platform-declared intent + constraints. Platform-asserted; operator validates and transforms to ContextRequest.",
  "type": "object",
  "required": ["spec_version", "message_id", "timestamp", "producer", "context", "identity", "extensions"],
  "properties": {
    "spec_version": {
      "type": "string",
      "description": "UCP specification version",
      "example": "1.0.0"
    },
    "message_id": {
      "type": "string",
      "description": "Unique identifier for this auction request",
      "example": "req_92fA1"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO timestamp when the platform generated the request",
      "example": "2025-11-14T18:22:00Z"
    },
    "producer": {
      "type": "object",
      "description": "Producer of the request (the AI platform/host). Not the content publisher.",
      "required": ["agent_id", "agent_role", "software", "software_version"],
      "additionalProperties": false,
      "properties": {
        "agent_id": {
          "type": "string",
          "description": "Identifier of the AI platform sending this request",
          "example": "openai_chat"
        },
        "agent_role": {
          "type": "string",
          "enum": ["platform"],
          "description": "Role of the request producer. Must be 'platform' (AI host). Reserve 'publisher' for content owners only.",
          "example": "platform"
        },
        "software": {
          "type": "string",
          "description": "Software name (e.g. chatgpt)",
          "example": "chatgpt"
        },
        "software_version": {
          "type": "string",
          "description": "Software version or model identifier",
          "example": "4.3-mini"
        }
      }
    },
    "context": {
      "type": "object",
      "description": "Context information (language, publisher, placement, device, geography)",
      "required": ["language", "publisher", "placement", "device", "geography"],
      "additionalProperties": false,
      "properties": {
        "language": {
          "type": "string",
          "pattern": "^[a-z]{2}-[A-Z]{2}$",
          "description": "User locale in BCP 47 format",
          "example": "en-US"
        },
        "publisher": {
          "type": "string",
          "description": "Publisher identifier (same as producer.agent_id in this context)",
          "example": "openai_chat"
        },
        "placement": {
          "type": "object",
          "required": ["ad_unit"],
          "additionalProperties": false,
          "properties": {
            "ad_unit": {
              "type": "string",
              "description": "Platform surface type: conversation, chat, voice, etc.",
              "example": "conversation"
            }
          }
        },
        "device": {
          "type": "object",
          "required": ["platform", "form_factor"],
          "additionalProperties": false,
          "properties": {
            "platform": { "type": "string", "description": "Device platform: web, mobile, etc.", "example": "web" },
            "form_factor": {
              "type": "string",
              "enum": ["mobile", "desktop", "tablet"],
              "example": "desktop"
            },
            "ua_hash": { "type": "string", "description": "Optional user agent hash", "example": "ua_hash_xyz" }
          }
        },
        "geography": {
          "type": "object",
          "required": ["country"],
          "additionalProperties": false,
          "properties": {
            "country": {
              "type": "string",
              "pattern": "^[A-Z]{2}$",
              "description": "User country code (ISO 3166-1 alpha-2)",
              "example": "US"
            }
          }
        }
      }
    },
    "identity": {
      "type": "object",
      "description": "Identity information",
      "required": ["namespace", "value_hash", "confidence"],
      "additionalProperties": false,
      "properties": {
        "namespace": { "type": "string", "example": "platform_user" },
        "value_hash": { "type": "string", "description": "Anonymous hashed user ID", "example": "user_hash_abc123" },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Confidence level for identity (0.0 to 1.0)",
          "example": 1
        }
      }
    },
    "extensions": {
      "type": "object",
      "description": "Vendor-namespaced data. AIP uses extensions.aip with intent, runtime, and auction sub-blocks. Consent logic must not touch auction logic.",
      "required": ["aip"],
      "properties": {
        "aip": {
          "type": "object",
          "description": "AIP extension: intent (consent matching), runtime (session/query), auction (monetization). Sub-blocks are separated so consent and auction do not mix.",
          "required": ["intent", "runtime"],
          "additionalProperties": false,
          "properties": {
            "intent": {
              "type": "object",
              "description": "Platform-declared intent for publisher consent gating. Must be explicit and structured so operator can match against publisher editorial_domains (e.g. aip.json).",
              "required": ["domain", "subdomain", "confidence"],
              "additionalProperties": false,
              "properties": {
                "domain": {
                  "type": "string",
                  "description": "Editorial domain (e.g. business, technology). Matched against publisher aip.json editorial_domains.",
                  "example": "business"
                },
                "subdomain": {
                  "type": "string",
                  "description": "Finer-grained subdomain (e.g. crm, ai)",
                  "example": "crm"
                },
                "confidence": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1,
                  "description": "Confidence in this intent classification",
                  "example": 0.91
                }
              }
            },
            "runtime": {
              "type": "object",
              "description": "Session and query context. Used for operator enrichment and ContextRequest generation.",
              "required": ["session_id", "turn_index", "query_text"],
              "additionalProperties": false,
              "properties": {
                "session_id": { "type": "string", "description": "Conversation or interaction session ID", "example": "sess_001" },
                "turn_index": { "type": "integer", "minimum": 0, "description": "Turn index in the conversation", "example": 3 },
                "query_text": { "type": "string", "description": "User's raw query text", "example": "best CRM for small teams" },
                "messages": {
                  "type": "array",
                  "description": "Optional short conversation history (last N turns)",
                  "items": {
                    "type": "object",
                    "properties": {
                      "role": { "type": "string", "enum": ["user", "assistant", "system"], "example": "user" },
                      "content": { "type": "string", "example": "best CRM tools?" },
                      "id": { "type": "string", "description": "Optional message ID" }
                    }
                  }
                },
                "latency_budget_ms": {
                  "type": "integer",
                  "minimum": 0,
                  "description": "Optional latency budget from platform (milliseconds)",
                  "example": 500
                }
              }
            },
            "auction": {
              "type": "object",
              "description": "Monetization parameters. Kept separate from intent so consent logic never touches auction logic.",
              "additionalProperties": false,
              "properties": {
                "pricing_model": {
                  "type": "string",
                  "enum": ["CPX", "CPC", "CPA"],
                  "description": "Preferred pricing model for this request",
                  "example": "CPX"
                },
                "cpx_floor": {
                  "type": "number",
                  "minimum": 0,
                  "description": "Minimum CPX (USD) required by the platform for this auction",
                  "example": 0.05
                },
                "currency": {
                  "type": "string",
                  "description": "Currency for pricing (ISO 4217)",
                  "example": "USD"
                }
              }
            }
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
