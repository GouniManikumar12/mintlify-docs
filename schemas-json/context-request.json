{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aip.dev/schemas/context-request-v1.0.json",
  "title": "ContextRequest",
  "description": "Operator-generated auction context sent to downstream brand agents after consent, policy, and eligibility have already been resolved.",
  "type": "object",
  "required": [
    "spec_version",
    "context_request_id",
    "source_request_id",
    "timestamp",
    "operator",
    "platform",
    "session",
    "surface",
    "intent",
    "allowed_formats"
  ],
  "additionalProperties": false,

  "properties": {
    "spec_version": {
      "type": "string",
      "const": "1.0"
    },

    "context_request_id": {
      "type": "string",
      "minLength": 1,
      "description": "Unique identifier for this operator-generated ContextRequest."
    },

    "source_request_id": {
      "type": "string",
      "minLength": 1,
      "description": "Reference to the originating PlatformRequest.request_id."
    },

    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "RFC 3339 timestamp when the operator generated this ContextRequest."
    },

    "operator": {
      "$ref": "#/$defs/operator"
    },

    "platform": {
      "$ref": "#/$defs/platform"
    },

    "session": {
      "$ref": "#/$defs/session"
    },

    "surface": {
      "$ref": "#/$defs/surface"
    },

    "auction": {
      "$ref": "#/$defs/auction"
    },

    "intent": {
      "$ref": "#/$defs/intent"
    },

    "verticals": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Normalized topical verticals identified by the operator."
    },

    "allowed_formats": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["weave", "tail", "product_card", "bridge"]
      },
      "description": "Creative formats allowed by the operator for rendering."
    },

    "consent": {
      "$ref": "#/$defs/downstreamConsent"
    },

    "usage_constraints": {
      "$ref": "#/$defs/usageConstraints"
    },

    "extensions": {
      "type": "object",
      "description": "Optional operator-defined extension metadata.",
      "additionalProperties": true
    }
  },

  "$defs": {
    "operator": {
      "type": "object",
      "required": ["operator_id"],
      "additionalProperties": false,
      "properties": {
        "operator_id": {
          "type": "string",
          "minLength": 1,
          "description": "Identifier of the operator that generated this ContextRequest."
        }
      }
    },

    "platform": {
      "type": "object",
      "required": ["platform_id", "software"],
      "additionalProperties": false,
      "properties": {
        "platform_id": {
          "type": "string",
          "minLength": 1,
          "description": "Identifier of the upstream AI platform where the interaction originated."
        },
        "software": {
          "type": "object",
          "required": ["name", "version"],
          "additionalProperties": false,
          "properties": {
            "name": {
              "type": "string",
              "description": "Software or product name."
            },
            "version": {
              "type": "string",
              "description": "Software version or model identifier."
            }
          }
        }
      }
    },

    "session": {
      "type": "object",
      "required": ["id", "turn_index"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "description": "Conversation or interaction session identifier."
        },
        "turn_index": {
          "type": "integer",
          "minimum": 0,
          "description": "How many turns into the session the user is."
        }
      }
    },

    "surface": {
      "type": "object",
      "required": ["channel", "interaction_mode", "platform"],
      "additionalProperties": false,
      "properties": {
        "channel": {
          "type": "string",
          "enum": [
            "conversation",
            "search_result",
            "assistant_panel",
            "embedded_assistant",
            "voice_assistant"
          ],
          "description": "Platform surface type where the interaction occurs."
        },
        "interaction_mode": {
          "type": "string",
          "enum": ["text", "voice", "multimodal"],
          "description": "Primary interaction modality."
        },
        "platform": {
          "type": "string",
          "enum": ["web", "mobile", "desktop_app", "browser_extension", "api", "other"],
          "description": "Runtime platform type."
        },
        "form_factor": {
          "type": "string",
          "enum": ["mobile", "desktop", "tablet", "speaker", "other"],
          "description": "Device form factor."
        },
        "country": {
          "type": "string",
          "pattern": "^[A-Z]{2}$",
          "description": "User country code (ISO 3166-1 alpha-2)."
        },
        "locale": {
          "type": "string",
          "description": "User locale in BCP 47 format (e.g. en-US)."
        }
      }
    },

    "auction": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "latency_budget_ms": {
          "type": "integer",
          "minimum": 0,
          "description": "Maximum time in milliseconds brand agents have to respond."
        },
        "context_window_ms": {
          "type": "integer",
          "minimum": 0,
          "description": "Time window in milliseconds within which the auction context is valid."
        }
      }
    },

    "intent": {
      "type": "object",
      "required": ["type", "decision_phase", "confidence", "summary"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "commercial",
            "transactional",
            "informational",
            "navigational",
            "support",
            "unsafe",
            "unknown"
          ],
          "description": "High-level intent classification."
        },
        "subtype": {
          "type": "string",
          "description": "Interaction pattern subtype (e.g. comparison, product_discovery)."
        },
        "decision_phase": {
          "type": "string",
          "enum": ["research", "consideration", "decision", "post_purchase", "unknown"],
          "description": "Commercial funnel decision phase."
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Calibrated confidence score for the intent classification."
        },
        "summary": {
          "type": "string",
          "description": "Operator-generated bid-safe summary. MUST NOT contain raw user queries or message content."
        },
        "relevance_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Operator-computed relevance score for auction ranking."
        },
        "iab_content": {
          "$ref": "#/$defs/iabContent"
        }
      }
    },

    "iabContent": {
      "type": "object",
      "required": ["taxonomy", "taxonomy_version", "tier1"],
      "additionalProperties": false,
      "description": "IAB Content Taxonomy mapping for the classified intent.",
      "properties": {
        "taxonomy": {
          "type": "string",
          "description": "Taxonomy name (e.g. IAB Content Taxonomy)."
        },
        "taxonomy_version": {
          "type": "string",
          "description": "Taxonomy version (e.g. 3.1)."
        },
        "tier1": {
          "type": "string",
          "description": "Top-level IAB category."
        },
        "tier2": {
          "type": "string",
          "description": "Second-level IAB category."
        },
        "tier3": {
          "type": "string",
          "description": "Third-level IAB category."
        },
        "tier4": {
          "type": "string",
          "description": "Fourth-level IAB category."
        }
      }
    },

    "downstreamConsent": {
      "type": "object",
      "additionalProperties": false,
      "description": "Downstream-effective consent permissions relevant to brand agents.",
      "properties": {
        "agent_participation": {
          "type": "boolean",
          "description": "Whether the user has consented to brand agent participation."
        },
        "measurement": {
          "type": "boolean",
          "description": "Whether the user has consented to measurement and attribution."
        }
      }
    },

    "usageConstraints": {
      "type": "object",
      "additionalProperties": false,
      "description": "Explicit usage restrictions that downstream brand agents MUST respect.",
      "properties": {
        "may_store": {
          "type": "boolean",
          "description": "Whether the brand agent may store the context data."
        },
        "may_train": {
          "type": "boolean",
          "description": "Whether the brand agent may use the data for model training."
        },
        "may_forward": {
          "type": "boolean",
          "description": "Whether the brand agent may forward the data to third parties."
        },
        "retention_ttl_seconds": {
          "type": "integer",
          "minimum": 0,
          "description": "Maximum retention time in seconds. Data MUST be discarded after this TTL."
        }
      }
    }
  }
}
